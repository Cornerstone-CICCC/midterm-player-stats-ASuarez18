---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Edit Player Profile">
  <!-- > HEADER -->
  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <a href="/players" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Directory
      </a>
      <h2 class="text-3xl font-bold tracking-tight text-slate-900">Edit Player Profile</h2>
    </div>

    <!-- - Delete Profile Button -->
    <button
      type="button"
      id="delete-btn"
      class="inline-flex items-center justify-center gap-2 border border-rose-200 bg-white hover:bg-rose-50 text-rose-600 font-semibold py-2.5 px-5 rounded-xl text-sm transition-all shadow-xs self-start sm:self-center cursor-pointer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="3 6 5 6 21 6"></polyline>
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
      </svg>
      Delete Profile
    </button>
  </div>

  <!-- > NOTIFICATION TOAST -->
  <div id="notification-banner" class="hidden p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all">
    <svg id="notification-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"></svg>
    <span id="notification-text"></span>
  </div>

  <!-- > LOADING PERFORMANCE CONTEXT CARD (SKELETON) -->
  <div id="loading-context-skeleton" class="bg-white border border-slate-200 rounded-3xl p-6 shadow-xs mb-6 animate-pulse flex items-center justify-center py-12 text-slate-400 font-medium">
    Loading player registry file...
  </div>

  <form id="edit-player-form" class="hidden space-y-6 pb-28">
    
    <!-- > 1. BIOGRAPHICAL IDENTITY CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        Biographical Identity
      </h3>
      
      <!-- - Player ID -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="flex flex-col gap-1.5 md:col-span-1">
          <label for="player_id_disabled" class="text-xs font-semibold text-slate-500">Player Token ID</label>
          <input type="text" id="player_id_disabled" disabled class="w-full bg-slate-50 border border-slate-200 py-2 px-3 rounded-lg text-sm font-bold text-slate-400 font-mono cursor-not-allowed" />
        </div>

        <!-- - Player Name -->
        <div class="flex flex-col gap-1.5 md:col-span-3">
          <label for="player_name" class="text-xs font-semibold text-slate-600">Full Player Name <span class="text-rose-500">*</span></label>
          <input type="text" id="player_name" name="player_name" required placeholder="e.g. Alejandro Suárez" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>
      </div>

      <!-- - Player Age -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
        <div class="flex flex-col gap-1.5">
          <label for="age" class="text-xs font-semibold text-slate-600">Age (15-50) <span class="text-rose-500">*</span></label>
          <input type="number" id="age" name="age" min="15" max="50" required placeholder="e.g. 22" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player Nationality -->
        <div class="flex flex-col gap-1.5">
          <label for="nationality" class="text-xs font-semibold text-slate-600">Nationality <span class="text-rose-500">*</span></label>
          <input type="text" id="nationality" name="nationality" required placeholder="e.g. Mexico" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player National Team -->
        <div class="flex flex-col gap-1.5">
          <label for="team" class="text-xs font-semibold text-slate-600">National Team <span class="text-rose-500">*</span></label>
          <input type="text" id="team" name="team" required placeholder="e.g. Mexico" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player Club Name -->
        <div class="flex flex-col gap-1.5">
          <label for="club_name" class="text-xs font-semibold text-slate-600">Club Name</label>
          <input type="text" id="club_name" name="club_name" placeholder="e.g. Whitecaps FC" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>
      </div>
    </div>

    <!-- > 2. TACTICAL & ATHLETIC SPECS -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
        Tactical & Athletic Specifications
      </h3>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <!-- - Player Position -->
        <div class="flex flex-col gap-1.5 col-span-2 md:col-span-1">
          <label for="position" class="text-xs font-semibold text-slate-600">Position <span class="text-rose-500">*</span></label>
          <select id="position" name="position" required class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700 cursor-pointer">
            <option value="Goalkeeper">Goalkeeper</option>
            <option value="Defender">Defender</option>
            <option value="Midfielder">Midfielder</option>
            <option value="Forward">Forward</option>
          </select>
        </div>

        <!-- - Player Jersey # -->
        <div class="flex flex-col gap-1.5">
          <label for="jersey_number" class="text-xs font-semibold text-slate-600">Jersey # <span class="text-rose-500">*</span></label>
          <input type="number" id="jersey_number" name="jersey_number" required min="1" max="99" placeholder="e.g. 10" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player Preferred Foot -->
        <div class="flex flex-col gap-1.5">
          <label for="preferred_foot" class="text-xs font-semibold text-slate-600">Preferred Foot</label>
          <select id="preferred_foot" name="preferred_foot" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700 cursor-pointer">
            <option value="">None</option>
            <option value="Left">Left</option>
            <option value="Right">Right</option>
            <option value="Both">Both</option>
          </select>
        </div>

        <!-- - Player Weigth -->
        <div class="flex flex-col gap-1.5">
          <label for="height_cm" class="text-xs font-semibold text-slate-600">Height (130-230 cm)</label>
          <input type="number" id="height_cm" name="height_cm" min="130" max="230" placeholder="e.g. 172" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player Weigth -->
        <div class="flex flex-col gap-1.5">
          <label for="weight_kg" class="text-xs font-semibold text-slate-600">Weight (40-150 kg)</label>
          <input type="number" id="weight_kg" name="weight_kg" min="40" max="150" placeholder="e.g. 72" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>
      </div>
    </div>

    <!-- > 3. TOURNAMENT STATS & RANKING -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        Tournament Historical Stats
      </h3>

      <!-- - Player Total Goals -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <div class="flex flex-col gap-1.5">
          <label for="total_goals_tournament" class="text-xs font-semibold text-slate-600">Total Goals</label>
          <input type="number" id="total_goals_tournament" name="total_goals_tournament" min="0" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player Total Assists -->
        <div class="flex flex-col gap-1.5">
          <label for="total_assists_tournament" class="text-xs font-semibold text-slate-600">Total Assists</label>
          <input type="number" id="total_assists_tournament" name="total_assists_tournament" min="0" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player Total Minutes -->
        <div class="flex flex-col gap-1.5">
          <label for="total_minutes_tournament" class="text-xs font-semibold text-slate-600">Total Minutes</label>
          <input type="number" id="total_minutes_tournament" name="total_minutes_tournament" min="0" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player POTM # Awards -->
        <div class="flex flex-col gap-1.5">
          <label for="player_of_match_awards" class="text-xs font-semibold text-slate-600">POTM Awards</label>
          <input type="number" id="player_of_match_awards" name="player_of_match_awards" min="0" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Player Global Ratings -->
        <div class="flex flex-col gap-1.5">
          <label for="tournament_rating" class="text-xs font-semibold text-slate-600">Global Rating (1-10)</label>
          <input 
            type="number" 
            step="0.01" 
            id="tournament_rating" 
            name="tournament_rating" 
            min="0"
            max="10"
            data-scale="10" 
            class="w-full py-2.5 px-3 rounded-lg text-sm font-bold focus:outline-hidden transition-all duration-200" 
          />
        </div>

        <!-- - Player Market Value -->
        <div class="flex flex-col gap-1.5">
          <label for="market_value_eur" class="text-xs font-semibold text-slate-600">Market Value (EUR)</label>
          <input type="number" id="market_value_eur" name="market_value_eur" min="0" placeholder="e.g. 15000000" class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700 font-mono" />
        </div>
      </div>
    </div>

    <!-- > 4. ACTION BUTTONS -->
    <div class="fixed bottom-0 left-0 md:left-64 right-0 bg-white border-t border-slate-200 p-4 px-6 flex justify-end gap-3 z-10 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
      <button type="button" onclick="window.history.back()" class="px-6 py-2.5 text-sm font-semibold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer">
        Cancel
      </button>
      <button type="submit" id="submit-btn" class="px-8 py-2.5 text-sm font-semibold text-white bg-[#2563eb] hover:bg-blue-700 rounded-xl shadow-md shadow-blue-500/20 transition-colors flex items-center gap-2 cursor-pointer">
        Update Profile
      </button>
    </div>
  </form>

  <!-- > DELETE CONFIRMATION MODAL -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-xs transition-opacity"></div>

    <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
      <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg p-6 space-y-4 border border-slate-100">
        <div class="flex items-center gap-3 text-rose-600">
          <div class="p-2 rounded-xl bg-rose-50 border border-rose-100 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900" id="modal-title">Delete Player Profile</h3>
        </div>
        
        <p class="text-sm text-slate-500 font-medium leading-relaxed">
          Are you sure you want to permanently delete this player file? If the player contains registered performances, the system database will refuse deletion to safeguard historical data integrity.
        </p>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="modal-cancel-btn" class="px-4 py-2.5 text-sm font-semibold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer">
            Cancel
          </button>
          <button type="button" id="modal-confirm-btn" class="px-5 py-2.5 text-sm font-semibold text-white bg-rose-600 hover:bg-rose-700 rounded-xl shadow-md shadow-rose-500/20 transition-colors cursor-pointer">
            Delete Permanently
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // > --- DOM ELEMENTS ---
  const form = document.getElementById("edit-player-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const deleteBtn = document.getElementById("delete-btn") as HTMLButtonElement;

  // > --- MODAL ELEMENTS ---
  const deleteModal = document.getElementById("delete-modal") as HTMLDivElement;
  const modalCancelBtn = document.getElementById("modal-cancel-btn") as HTMLButtonElement;
  const modalConfirmBtn = document.getElementById("modal-confirm-btn") as HTMLButtonElement;

  // > --- CONTEXT ELEMENTS ---
  const loadingSkeleton = document.getElementById("loading-context-skeleton");

  const banner = document.getElementById("notification-banner");
  const bannerText = document.getElementById("notification-text");
  const bannerIcon = document.getElementById("notification-icon");

  // > --- URL PARAMS ---
  const urlParams = new URLSearchParams(window.location.search);
  const playerId = urlParams.get("id");

  if (!playerId) {
    window.location.href = "/players";
  }

  /**
   * @function showNotification
   * @description Displays a notification banner with a message and an icon indicating success or error.
   * @param message - The message to display in the notification banner.
   * @param isError - A boolean indicating whether the notification is an error (true) or success (false).
   * @returns {void}
   */
  const showNotification = (message: string, isError: boolean) => {
    if (!banner || !bannerText || !bannerIcon) return;
    banner.className = `p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all ${isError ? 'bg-rose-50 text-rose-700 border border-rose-200' : 'bg-green-50 text-green-700 border border-green-200'}`;
    bannerText.textContent = message;
    bannerIcon.innerHTML = isError 
      ? '<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>' 
      : '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>';
    banner.classList.remove("hidden");
    
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // --- DYNAMIC INPUT COLORING FOR RATING ---
  const ratingInputs = document.querySelectorAll<HTMLInputElement>('input[data-scale]');

  function updateInputColor(input: HTMLInputElement) {
    const val = parseFloat(input.value) || 0;
    
    input.classList.remove(
      'bg-green-50', 'text-green-700', 'border-green-200', 'focus:border-green-500', 'focus:ring-green-500/10',
      'bg-amber-50', 'text-amber-700', 'border-amber-200', 'focus:border-amber-500', 'focus:ring-amber-500/10',
      'bg-rose-50', 'text-rose-700', 'border-rose-200', 'focus:border-rose-500', 'focus:ring-rose-500/10',
      'border-slate-200', 'text-slate-700'
    );
    
    let colorClass = '';
    if (val >= 7.5) colorClass = 'bg-green-50 text-green-700 border-green-200 focus:border-green-500 focus:ring-green-500/10';
    else if (val >= 6.5) colorClass = 'bg-amber-50 text-amber-700 border-amber-200 focus:border-amber-500 focus:ring-amber-500/10';
    else colorClass = 'bg-rose-50 text-rose-700 border-rose-200 focus:border-rose-500 focus:ring-rose-500/10';
    
    input.className = `w-full border py-2.5 px-3 rounded-lg text-sm font-bold focus:ring-2 focus:outline-hidden transition-all duration-200 ${colorClass}`;
  }

  ratingInputs.forEach(input => {
    input.addEventListener('input', () => updateInputColor(input));
  });

  // > --- PREVENT NEGATIVE VALUES IN NUMBER INPUTS ---
  const allNumberInputs = document.querySelectorAll<HTMLInputElement>('input[type="number"]');
  allNumberInputs.forEach(input => {
    input.addEventListener('keydown', (e) => {
      if (e.key === '-' || e.key === 'e' || e.key === 'E') e.preventDefault();
    });
    input.addEventListener('input', () => {
      if (parseFloat(input.value) < 0) {
        input.value = "0";
        if (input.hasAttribute('data-scale')) updateInputColor(input);
      }
    });
  });

  // > --- LOAD PERFORMANCE DATA FETCH ---
  /**
   * @function loadPlayerProfileData
   * @description Fetches the player profile data from the server and populates the form fields
   * @returns {Promise<void>}
   */
  async function loadPlayerProfileData() {
    try {
      const response = await fetch(`http://localhost:3000/api/players/${playerId}`);
      
      if (!response.ok) {
        throw new Error("The requested player record does not exist or has been modified.");
      }
      
      const data = await response.json();

      // Configure the disabled input for player ID
      const disabledIdInput = document.getElementById("player_id_disabled") as HTMLInputElement;
      if (disabledIdInput) disabledIdInput.value = data.player_id;

      // Prefill form fields with fetched data
      Object.keys(data).forEach(field => {
        const input = form.querySelector(`[name="${field}"]`) as HTMLInputElement | HTMLSelectElement;
        if (input) {
          input.value = data[field];
          if (input instanceof HTMLInputElement && input.hasAttribute('data-scale')) {
            updateInputColor(input);
          }
        }
      });

      // Hide loading skeleton and show metadata card after data is loaded
      loadingSkeleton?.classList.add("hidden");
      form?.classList.remove("hidden");

    } catch (error: any) {
      showNotification(`${error.message} Redirecting to registry directory...`, true);
      setTimeout(() => { window.location.href = "/players"; }, 2500);
    }
  }

  // > --- FORM SUBMISSION HANDLER ---
  /**
   * @function handleFormSubmit
   * @description Handles the form submission for updating player data
   * @param e - The submit event object
   * @returns {Promise<void>}
   */
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.innerHTML = "Updating...";

    const formData = new FormData(form);
    const payload: Record<string, any> = {};

    const validationRules: Record<string, { min: number; max: number; msg: string }> = {
      age: { min: 15, max: 50, msg: "Age must be between 15 and 50 years." },
      height_cm: { min: 130, max: 230, msg: "Height must be between 130 and 230 cm." },
      weight_kg: { min: 40, max: 150, msg: "Weight must be between 40 and 150 kg." },
      jersey_number: { min: 1, max: 99, msg: "Jersey number must be between 1 and 99." },
      tournament_rating: { min: 0, max: 10, msg: "Global Rating must be between 0 and 10." }
    };

    for (const [key, value] of formData.entries()) {
      if (value !== "") {
        if (
          key !== "player_id" && 
          key !== "player_name" && 
          key !== "nationality" && 
          key !== "team" && 
          key !== "position" && 
          key !== "preferred_foot" && 
          key !== "club_name" && 
          !isNaN(Number(value))
        ) {
          const parsedValue = Number(value);

          if (validationRules[key]) {
            const rule = validationRules[key];
            if (parsedValue < rule.min || parsedValue > rule.max) {
              showNotification(`Validation Error: ${rule.msg}`, true);
              submitBtn.disabled = false;
              submitBtn.innerHTML = "Update Profile";
              return;
            }
          }
          payload[key] = parsedValue;
        } else {
          payload[key] = value;
        }
      }
    }

    try {
      const response = await fetch(`http://localhost:3000/api/players/${playerId}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        const errData = await response.json();
        throw new Error(errData.details || errData.error || "Failed to sync changes with data server.");
      }

      showNotification("Player profile updated and indexed successfully!", false);
      setTimeout(() => { window.location.href = "/players"; }, 1200);

    } catch (error: any) {
      console.error(error);
      showNotification(error.message, true);
      submitBtn.disabled = false;
      submitBtn.innerHTML = "Update Profile";
    }
  });

  // > --- DELETE PERFORMANCE HANDLER ---
  /**
   * @function openDeleteModal
   * @description Opens the delete confirmation modal when the delete button is clicked
   */
  deleteBtn?.addEventListener("click", () => deleteModal?.classList.remove("hidden"));

  /**
   * @function closeDeleteModalOnOverlay
   * @description Closes the delete confirmation modal when the user clicks anywhere on the dark overlay background
   */
  modalCancelBtn?.addEventListener("click", () => deleteModal?.classList.add("hidden"));

  /**
   * @function closeDeleteModalOnOverlay
   * @description Closes the delete confirmation modal when the user clicks anywhere on the dark overlay background
   */
  deleteModal?.addEventListener("click", (e) => {
    if (!(e.target as HTMLElement).closest(".bg-white")) {
      deleteModal.classList.add("hidden");
    }
  });

  /**
   * @function confirmDeletePerformance
   * @description Confirms the deletion of the performance record and sends a DELETE request to the API
   * @returns {Promise<void>}
   */
  modalConfirmBtn?.addEventListener("click", async () => {
    modalConfirmBtn.disabled = true;
    modalConfirmBtn.innerHTML = "Deleting...";

    try {
      const response = await fetch(`http://localhost:3000/api/players/${playerId}`, {
        method: "DELETE"
      });

      if (!response.ok) {
        const errData = await response.json();
        throw new Error(errData.error || "Integrity error: Cannot wipe player profile due to foreign relations.");
      }

      deleteModal?.classList.add("hidden");
      showNotification("Player file permanently dropped from system index.", false);
      setTimeout(() => { window.location.href = "/players"; }, 1200);

    } catch (error: any) {
      console.error(error);
      deleteModal?.classList.add("hidden"); 
      showNotification(error.message, true);
      modalConfirmBtn.disabled = false;
      modalConfirmBtn.innerHTML = "Delete Permanently";
    }
  });

  // On page load, fetch and populate the player data
  loadPlayerProfileData();
</script>