---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Tournament Roster & Players">
  <!-- CABECERA Y HERRAMIENTAS (Buscador, Filtros, Agregar) -->
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-8">
    <div>
      <h2 class="text-3xl font-bold tracking-tight text-slate-900">Players Directory</h2>
      <p class="text-slate-500 mt-1">Manage the tournament roster, positions, and player biographies.</p>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <!-- Input de Búsqueda -->
      <div class="relative w-full sm:w-64 md:w-72">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </span>
        <input
          type="text"
          id="search-input"
          placeholder="Search players by name..."
          class="w-full bg-white border border-slate-200 text-slate-700 pl-10 pr-4 py-2.5 rounded-xl text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 focus:outline-hidden transition-all shadow-xs"
        />
      </div>

      <!-- Botón de Filtros Avanzados -->
      <button
        id="open-filters-btn"
        class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 bg-white border border-slate-200 cursor-pointer hover:bg-slate-50 text-slate-700 font-semibold py-2.5 px-4 rounded-xl text-sm shadow-xs transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
        </svg>
        Filters
      </button>

      <!-- Botón Crear Jugador -->
      <a
        href="/players/create"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-[#2563eb] hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-xl text-sm shadow-md shadow-blue-500/10 hover:shadow-lg transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/xl" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <line x1="19" y1="11" x2="19" y2="17"></line>
          <line x1="16" y1="14" x2="22" y2="14"></line>
        </svg>
        Add Player
      </a>
    </div>
  </div>

  <!-- BANNER DE ERROR DE CONEXIÓN -->
  <div id="error-banner" class="hidden bg-rose-50 border border-rose-100 text-rose-700 p-6 rounded-2xl items-center gap-4 shadow-xs mb-6">
    <div class="bg-rose-100 p-3 rounded-xl text-rose-600 shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
    </div>
    <div>
      <h4 class="font-bold">Backend Connection Error</h4>
      <p id="error-text" class="text-sm text-rose-600/90 mt-1">Failed to fetch the roster registry from the database server.</p>
    </div>
  </div>

  <!-- CONTROL DE PAGINACIÓN Y LÍMITES -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div class="flex items-center gap-2 text-sm text-slate-500 font-medium">
      <span>Show</span>
      <select
        id="limit-select"
        class="bg-white border border-slate-200 text-slate-700 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden transition-all cursor-pointer"
      >
        <option value="10">10</option>
        <option value="25" selected>25</option>
        <option value="50">50</option>
        <option value="100">100</option>
      </select>
      <span>entries</span>
    </div>

    <div class="flex items-center gap-4 self-end sm:self-auto">
      <span id="pagination-info" class="text-xs sm:text-sm text-slate-500 font-medium">Loading roster stats...</span>
      <div id="pagination-controls" class="flex items-center gap-1.5"></div>
    </div>
  </div>

  <!-- TABLA DE JUGADORES REGISTRADOS -->
  <div class="bg-white border border-slate-100 rounded-3xl shadow-xs overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-left text-sm text-slate-600">
        <thead>
          <tr class="bg-slate-50/75 border-b border-slate-100 text-xs font-bold uppercase tracking-wider text-slate-400 select-none">
            <th class="px-6 py-4 cursor-pointer hover:bg-slate-100/50 hover:text-slate-700 transition-colors" data-sort="player_name">
              <div class="flex items-center gap-1">Player <span class="sort-icon">↑</span></div>
            </th>
            <th class="px-6 py-4 cursor-pointer hover:bg-slate-100/50 hover:text-slate-700 transition-colors" data-sort="team">
              <div class="flex items-center gap-1">Team <span class="sort-icon"></span></div>
            </th>
            <th class="px-6 py-4 cursor-pointer hover:bg-slate-100/50 hover:text-slate-700 transition-colors hidden sm:table-cell" data-sort="position">
              <div class="flex items-center gap-1">Position <span class="sort-icon"></span></div>
            </th>
            <th class="px-6 py-4 cursor-pointer hover:bg-slate-100/50 hover:text-slate-700 transition-colors text-center hidden md:table-cell" data-sort="jersey_number">
              <div class="flex items-center justify-center gap-1">Jersey <span class="sort-icon"></span></div>
            </th>
            <th class="px-6 py-4 cursor-pointer hover:bg-slate-100/50 hover:text-slate-700 transition-colors text-center hidden md:table-cell" data-sort="age">
              <div class="flex items-center justify-center gap-1">Age <span class="sort-icon"></span></div>
            </th>
            <th class="px-6 py-4 text-center">Actions</th>
          </tr>
        </thead>
        <tbody id="players-tbody" class="divide-y divide-slate-100/60">
        </tbody>
      </table>
    </div>
  </div>

  <!-- OVERLAY / BACKDROP PARA FILTROS DESLIZANTES -->
  <div id="filter-backdrop" class="fixed inset-0 bg-slate-950/40 backdrop-blur-xs z-50 hidden opacity-0 transition-opacity duration-300"></div>

  <!-- PANEL DE FILTROS AVANZADOS DESLIZANTE -->
  <div id="filter-panel" class="fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl z-50 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
      <h3 class="font-bold text-slate-800 text-lg flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
        </svg>
        Filter Directory
      </h3>
      <button id="close-filters-btn" class="text-slate-400 hover:text-slate-700 bg-white rounded-lg p-1.5 border border-slate-200 shadow-xs transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="p-6 flex-1 overflow-y-auto space-y-6">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Sort by Attribute</label>
        <select id="filter-sort-by" class="w-full bg-white border border-slate-200 text-slate-700 py-2.5 px-4 rounded-xl text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 focus:outline-hidden transition-all shadow-xs cursor-pointer">
          <option value="player_name">Player Name</option>
          <option value="team">Team / Nation</option>
          <option value="position">Tactical Position</option>
          <option value="jersey_number">Jersey Number</option>
          <option value="age">Player Age</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Sorting Direction</label>
        <div class="grid grid-cols-2 gap-3">
          <label class="cursor-pointer">
            <input type="radio" name="sort-order" value="ASC" class="peer sr-only" checked />
            <div class="text-center py-2.5 border border-slate-200 rounded-xl text-sm font-medium text-slate-600 peer-checked:bg-blue-50 peer-checked:border-blue-500 peer-checked:text-blue-700 transition-all shadow-xs peer-checked:shadow-none">
              Low to High (↑)
            </div>
          </label>
          <label class="cursor-pointer">
            <input type="radio" name="sort-order" value="DESC" class="peer sr-only" />
            <div class="text-center py-2.5 border border-slate-200 rounded-xl text-sm font-medium text-slate-600 peer-checked:bg-blue-50 peer-checked:border-blue-500 peer-checked:text-blue-700 transition-all shadow-xs peer-checked:shadow-none">
              High to Low (↓)
            </div>
          </label>
        </div>
      </div>
    </div>

    <div class="p-6 border-t border-slate-100 bg-slate-50/50 flex gap-3">
      <button id="reset-filters-btn" class="flex-1 bg-white border border-slate-200 text-slate-700 font-semibold py-2.5 rounded-xl text-sm hover:bg-slate-50 transition-colors shadow-xs cursor-pointer">
        Reset
      </button>
      <button id="apply-filters-btn" class="flex-1 bg-[#2563eb] text-white font-semibold py-2.5 rounded-xl text-sm hover:bg-blue-700 transition-colors shadow-md shadow-blue-500/20 cursor-pointer">
        Apply Filters
      </button>
    </div>
  </div>
</Layout>

<script>
  // --- ESTADO GLOBAL DE JUGADORES ---
  let state = {
    page: 1,
    limit: 25,
    search: "",
    sortBy: "player_name",
    sortOrder: "ASC" as "ASC" | "DESC",
  };

  // --- REFERENCIAS ELEMENTOS DEL DOM ---
  const tbody = document.getElementById("players-tbody");
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const limitSelect = document.getElementById("limit-select") as HTMLSelectElement;
  const paginationInfo = document.getElementById("pagination-info");
  const paginationControls = document.getElementById("pagination-controls");
  const errorBanner = document.getElementById("error-banner");
  const errorText = document.getElementById("error-text");

  // Elementos de Filtros Deslizantes
  const openFiltersBtn = document.getElementById("open-filters-btn");
  const closeFiltersBtn = document.getElementById("close-filters-btn");
  const filterBackdrop = document.getElementById("filter-backdrop");
  const filterPanel = document.getElementById("filter-panel");
  const filterSortBy = document.getElementById("filter-sort-by") as HTMLSelectElement;
  const applyFiltersBtn = document.getElementById("apply-filters-btn");
  const resetFiltersBtn = document.getElementById("reset-filters-btn");

  // --- UTILERÍAS VISUALES ---
  const getFlagEmoji = (country: string): string => {
    const flags: Record<string, string> = {
      Spain: "🇪🇸", France: "🇫🇷", Argentina: "🇦🇷", England: "🏴󠁧󠁢󠁥󠁮󠁧󠁿", Portugal: "🇵🇹", 
      Netherlands: "🇳🇱", Germany: "🇩🇪", Brazil: "🇧🇷", Belgium: "🇧🇪", Mexico: "🇲🇽", 
      USA: "🇺🇸", "South Africa": "🇿🇦", Canada: "🇨🇦", Australia: "🇦🇺", Iraq: "🇮🇶"
    };
    return flags[country] || "🏳️";
  };

  const getInitials = (name: string): string =>
    name.split(" ").map((n) => n[0]).slice(0, 2).join("").toUpperCase();

  // --- CONEXIÓN API Y RENDERIZADO DE TABLA ---
  async function fetchPlayers() {
    if (!tbody) return;

    // Spinner de carga reactivo dentro del cuerpo
    tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-slate-400 font-medium"><div class="flex items-center justify-center gap-3"><svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Loading roster data...</span></div></td></tr>`;
    errorBanner?.classList.add("hidden");

    try {
      const url = new URL("http://localhost:3000/api/players");
      url.searchParams.set("page", state.page.toString());
      url.searchParams.set("limit", state.limit.toString());
      if (state.search) url.searchParams.set("search", state.search);
      url.searchParams.set("sortBy", state.sortBy);
      url.searchParams.set("sortOrder", state.sortOrder);

      const response = await fetch(url.toString());
      if (!response.ok) throw new Error("Database server rejected the catalog fetch query.");
      
      const result = await response.json();
      tbody.innerHTML = "";

      // Si la API devuelve un arreglo directo en vez de paginado, creamos un fallback estructural compatible
      const data = result.data !== undefined ? result.data : result;
      const total = result.total !== undefined ? result.total : data.length;

      if (data.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-slate-400 font-medium">No players match the chosen search parameters.</td></tr>`;
        if (paginationInfo) paginationInfo.textContent = "0 entries";
        if (paginationControls) paginationControls.innerHTML = "";
        return;
      }

      data.forEach((player: any) => {
        const tr = document.createElement("tr");
        tr.className = "hover:bg-slate-50/40 cursor-pointer transition-colors border-b border-slate-100/60";
        
        // Redirección por clic en fila usando Query Parameters estructurales
        tr.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          if (target.closest("a, button")) return; // Si hace click en acciones, ignorar fila
          window.location.href = `/players/edit?id=${player.player_id}`;
        });

        tr.innerHTML = `
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-slate-100 to-slate-200 text-slate-600 font-bold text-xs flex items-center justify-center shrink-0 border border-slate-100 shadow-xs uppercase">
                ${getInitials(player.player_name || "—")}
              </div>
              <span class="font-bold text-slate-900">${player.player_name || "—"}</span>
            </div>
          </td>
          <td class="px-6 py-4 text-slate-700 font-semibold">
            <span>${getFlagEmoji(player.team)}</span> <span>${player.team || "—"}</span>
          </td>
          <td class="px-6 py-4 text-slate-600 font-medium hidden sm:table-cell">${player.position || "—"}</td>
          <td class="px-6 py-4 text-center hidden md:table-cell font-mono text-slate-500 font-bold">#${player.jersey_number ?? "—"}</td>
          <td class="px-6 py-4 text-center hidden md:table-cell text-slate-600 font-medium">${player.age || "—"} Yrs</td>
          <td class="px-6 py-4 text-center">
            <div class="flex items-center justify-center gap-2">
              <a href="/players/edit?id=${player.player_id}" class="text-blue-600 hover:text-blue-800 p-2 hover:bg-blue-50 border border-transparent hover:border-blue-100 rounded-xl transition-colors shadow-none hover:shadow-xs">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </a>
            </div>
          </td>
        `;
        tbody.appendChild(tr);
      });

      if (paginationInfo) {
        paginationInfo.textContent = `${(state.page - 1) * state.limit + 1}-${Math.min(state.page * state.limit, total)} of ${total.toLocaleString()}`;
      }
      renderPaginationButtons(total);
      syncUIStates();

    } catch (error: any) {
      console.error(error);
      if (tbody) tbody.innerHTML = `<tr><td colspan="6" class="text-center text-rose-500 py-12 font-medium">Critical error communicating with directory endpoint.</td></tr>`;
      if (errorText) errorText.textContent = error.message || "Failed to establish a data stream pipeline.";
      errorBanner?.classList.remove("hidden");
    }
  }

  // --- SINCRONIZACIÓN DE COMPONENTES INTERNOS ---
  function syncUIStates() {
    // Sincronizar iconos de las cabeceras de la tabla
    document.querySelectorAll("thead th[data-sort]").forEach((header) => {
      const field = header.getAttribute("data-sort");
      const icon = header.querySelector(".sort-icon");
      if (icon) {
        if (field === state.sortBy) {
          icon.textContent = state.sortOrder === "ASC" ? "↑" : "↓";
          header.classList.add("text-blue-600", "font-bold");
        } else {
          icon.textContent = "";
          header.classList.remove("text-blue-600", "font-bold");
        }
      }
    });

    // Sincronizar los campos internos de la tarjeta deslizante de filtros
    if (filterSortBy) filterSortBy.value = state.sortBy;
    const radio = document.querySelector(`input[name="sort-order"][value="${state.sortOrder}"]`) as HTMLInputElement;
    if (radio) radio.checked = true;
  }

  // --- CONTROL GESTIÓN PANEL FILTROS ---
  const toggleFiltersPanel = (open: boolean) => {
    if (open) {
      filterBackdrop?.classList.remove("hidden");
      filterPanel?.classList.remove("translate-x-full");
      setTimeout(() => filterBackdrop?.classList.replace("opacity-0", "opacity-100"), 10);
      syncUIStates();
    } else {
      filterPanel?.classList.add("translate-x-full");
      filterBackdrop?.classList.replace("opacity-100", "opacity-0");
      setTimeout(() => filterBackdrop?.classList.add("hidden"), 300);
    }
  };

  openFiltersBtn?.addEventListener("click", () => toggleFiltersPanel(true));
  closeFiltersBtn?.addEventListener("click", () => toggleFiltersPanel(false));
  filterBackdrop?.addEventListener("click", () => toggleFiltersPanel(false));

  applyFiltersBtn?.addEventListener("click", () => {
    const radioChecked = document.querySelector('input[name="sort-order"]:checked') as HTMLInputElement;
    state.sortBy = filterSortBy.value;
    state.sortOrder = radioChecked.value as "ASC" | "DESC";
    state.page = 1;
    fetchPlayers();
    toggleFiltersPanel(false);
  });

  resetFiltersBtn?.addEventListener("click", () => {
    state.sortBy = "player_name";
    state.sortOrder = "ASC";
    syncUIStates();
  });

  // --- ESCUCHADORES DE CLICS EN CABECERAS PARA ORDENADO ---
  document.querySelectorAll("thead th[data-sort]").forEach((th) => {
    th.addEventListener("click", () => {
      const field = th.getAttribute("data-sort") || "player_name";
      if (state.sortBy === field) {
        state.sortOrder = state.sortOrder === "ASC" ? "DESC" : "ASC";
      } else {
        state.sortBy = field;
        state.sortOrder = "ASC";
      }
      state.page = 1;
      fetchPlayers();
    });
  });

  // --- DEBOUNCE CAPTURA BUSCADOR ---
  let debounceTimeout: any;
  searchInput?.addEventListener("input", (e) => {
    clearTimeout(debounceTimeout);
    debounceTimeout = setTimeout(() => {
      state.search = (e.target as HTMLInputElement).value.trim();
      state.page = 1;
      fetchPlayers();
    }, 350);
  });

  // --- SELECTOR DE RANGO DE FILAS ---
  limitSelect?.addEventListener("change", (e) => {
    state.limit = parseInt((e.target as HTMLSelectElement).value, 10);
    state.page = 1;
    fetchPlayers();
  });

  // --- RENDERIZADOR COMPLETO DE BOTONES PAGINACIÓN ---
  function renderPaginationButtons(totalRows: number) {
    if (!paginationControls) return;
    paginationControls.innerHTML = "";
    const totalPages = Math.ceil(totalRows / state.limit);
    if (totalPages <= 1) return;

    const createBtn = (pageNum: number | string, text: string, disabled = false, isActive = false) => {
      const btn = document.createElement("button");
      btn.className = `min-w-8 h-8 px-2 flex items-center justify-center rounded-lg text-sm font-semibold transition-all ${isActive ? "bg-[#2563eb] text-white shadow-md shadow-blue-500/15" : disabled ? "text-slate-300 cursor-not-allowed" : "bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 cursor-pointer"}`;
      btn.innerHTML = text;
      if (!disabled && typeof pageNum === "number") {
        btn.addEventListener("click", () => {
          state.page = pageNum;
          fetchPlayers();
        });
      }
      return btn;
    };

    // Botón Atrás
    paginationControls.appendChild(
      createBtn(state.page - 1, `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>`, state.page === 1)
    );

    const pages = [];
    if (totalPages <= 5) {
      for (let i = 1; i <= totalPages; i++) pages.push(i);
    } else if (state.page <= 3) {
      pages.push(1, 2, 3, "...", totalPages);
    } else if (state.page >= totalPages - 2) {
      pages.push(1, "...", totalPages - 2, totalPages - 1, totalPages);
    } else {
      pages.push(1, "...", state.page, "...", totalPages);
    }

    pages.forEach((p) =>
      paginationControls.appendChild(
        p === "..." ? createBtn(0, "...", true) : createBtn(p as number, p.toString(), false, state.page === p)
      )
    );

    // Botón Siguiente
    paginationControls.appendChild(
      createBtn(state.page + 1, `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>`, state.page === totalPages)
    );
  }

  // Carga inicial
  fetchPlayers();
</script>