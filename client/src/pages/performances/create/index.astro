---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Add Performance">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Performances
      </a>
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Add Performance</h2>
    </div>
  </div>

  <div id="notification-banner" class="hidden p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all">
    <svg id="notification-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"></svg>
    <span id="notification-text"></span>
  </div>

  <form id="create-performance-form" class="space-y-6 pb-24">
    
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-4">
          <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2">Player Details</h3>
          <div class="flex flex-col gap-1.5">
            <label for="player_id" class="text-xs font-semibold text-slate-600">Select Player <span class="text-rose-500">*</span></label>
            <select id="player_id" name="player_id" required class="w-full bg-slate-50 border border-slate-200 text-slate-800 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden">
              <option value="" disabled selected>Loading...</option>
            </select>
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2">Match Details</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label for="match_id" class="text-xs font-semibold text-slate-600">Select Match <span class="text-rose-500">*</span></label>
              <select id="match_id" name="match_id" required class="w-full bg-slate-50 border border-slate-200 text-slate-800 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden">
                <option value="" disabled selected>Loading...</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600">Opponent Team</label>
              <input type="text" name="opponent_team" placeholder="e.g. Senegal" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600">Match Result</label>
              <select name="match_result" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700">
                <option value="" disabled selected>Select...</option>
                <option value="W">Win</option>
                <option value="D">Draw</option>
                <option value="L">Loss</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600">Team Goals</label>
              <input type="number" name="goals_team" value="0" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-slate-600">Opp. Goals</label>
              <input type="number" name="goals_opponent" value="0" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. GRID PRINCIPAL DE TARJETAS (Forzado a 2 columnas en Desktop) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <!-- ATTACKING CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
          Attacking & Passing
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
          <!-- Iteración compacta de inputs -->
          {[
            { id: "goals", label: "Goals" },
            { id: "assists", label: "Assists" },
            { id: "shots", label: "Shots" },
            { id: "shots_on_target", label: "On Target" },
            { id: "expected_goals_xg", label: "xG" },
            { id: "expected_assists_xa", label: "xA" },
            { id: "key_passes", label: "Key Passes" },
            { id: "total_passes", label: "Total Passes" },
            { id: "successful_passes", label: "Succ. Passes" },
            { id: "crosses", label: "Crosses" },
            { id: "successful_crosses", label: "Succ. Crosses" },
            { id: "dribbles_attempted", label: "Dribbles" },
            { id: "successful_dribbles", label: "Succ. Dribbles" },
            { id: "offsides", label: "Offsides" }
          ].map(field => (
            <div class="flex flex-col gap-1">
              <label class="text-[10px] font-semibold text-slate-500">{field.label}</label>
              <input type="number" step="any" name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
            </div>
          ))}
        </div>
      </div>

      <!-- DEFENSIVE CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          Defensive & Goalkeeping
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
          {[
            { id: "tackles", label: "Tackles" },
            { id: "interceptions", label: "Interceptions" },
            { id: "clearances", label: "Clearances" },
            { id: "blocks", label: "Blocks" },
            { id: "recoveries", label: "Recoveries" },
            { id: "defensive_actions", label: "Def. Actions" },
            { id: "aerial_duels_won", label: "Duels Won" },
            { id: "aerial_duels_lost", label: "Duels Lost" },
            { id: "fouls_committed", label: "Fouls Com." },
            { id: "fouls_suffered", label: "Fouls Drawn" },
            { id: "yellow_cards", label: "Yellow Card" },
            { id: "red_cards", label: "Red Card" },
            { id: "saves", label: "GK Saves" },
            { id: "save_percentage", label: "Save %" },
            { id: "goals_conceded", label: "Goals Conc." },
            { id: "clean_sheet", label: "Clean Sheet" }
          ].map(field => (
            <div class="flex flex-col gap-1">
              <label class="text-[10px] font-semibold text-slate-500">{field.label}</label>
              <input type="number" step="any" name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
            </div>
          ))}
        </div>
      </div>

      <!-- PHYSICAL CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M13 4v16"></path><path d="M17 4v16"></path><path d="M19 8H5"></path><path d="M19 16H5"></path></svg>
          Physical
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
          {[
            { id: "minutes_played", label: "Minutes" },
            { id: "distance_covered_km", label: "Distance (km)" },
            { id: "sprint_distance_km", label: "Sprint (km)" },
            { id: "top_speed_kmh", label: "Top Speed" },
            { id: "accelerations", label: "Accels" },
            { id: "decelerations", label: "Decels" },
            { id: "stamina_score", label: "Stamina" }
          ].map(field => (
            <div class="flex flex-col gap-1">
              <label class="text-[10px] font-semibold text-slate-500">{field.label}</label>
              <input type="number" step="any" name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
            </div>
          ))}
        </div>
      </div>

      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          Ratings (0-10 or 0-100)
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
          <div class="flex flex-col gap-1">
            <label class="text-[10px] font-semibold text-slate-500">Match Rating</label>
            <input type="number" step="any" name="player_rating" value="0" class="w-full bg-green-50 border border-green-200 text-green-700 py-1.5 px-3 rounded-lg text-sm font-bold focus:border-green-500 focus:outline-hidden" />
          </div>
          {[
            { id: "pass_accuracy", label: "Pass Acc. %" },
            { id: "performance_score", label: "Perf. Score" },
            { id: "offensive_contribution", label: "Offensive" },
            { id: "defensive_contribution", label: "Defensive" },
            { id: "possession_impact", label: "Possession" },
            { id: "pressure_resistance", label: "Press. Resist" },
            { id: "creativity_score", label: "Creativity" },
            { id: "consistency_score", label: "Consistency" },
            { id: "clutch_performance_score", label: "Clutch Perf." }
          ].map(field => (
            <div class="flex flex-col gap-1">
              <label class="text-[10px] font-semibold text-slate-500">{field.label}</label>
              <input type="number" step="any" name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
            </div>
          ))}
        </div>
      </div>

    </div>

    <div class="fixed bottom-0 left-0 md:left-64 right-0 bg-white border-t border-slate-200 p-4 px-6 flex justify-end gap-3 z-10 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
      <button type="button" onclick="window.history.back()" class="px-6 py-2.5 text-sm font-semibold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-xl transition-colors">
        Cancel
      </button>
      <button type="submit" id="submit-btn" class="px-8 py-2.5 text-sm font-semibold text-white bg-[#2563eb] hover:bg-blue-700 rounded-xl shadow-md transition-colors flex items-center gap-2">
        Save Performance
      </button>
    </div>
  </form>
</Layout>

<script>
  const form = document.getElementById("create-performance-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const playerSelect = document.getElementById("player_id") as HTMLSelectElement;
  const matchSelect = document.getElementById("match_id") as HTMLSelectElement;
  
  const banner = document.getElementById("notification-banner");
  const bannerText = document.getElementById("notification-text");
  const bannerIcon = document.getElementById("notification-icon");

  const showNotification = (message: string, isError: boolean) => {
    if (!banner || !bannerText || !bannerIcon) return;
    banner.className = `p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all ${isError ? 'bg-rose-50 text-rose-700 border border-rose-200' : 'bg-green-50 text-green-700 border border-green-200'}`;
    bannerText.textContent = message;
    bannerIcon.innerHTML = isError 
      ? '<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>' 
      : '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>';
    banner.classList.remove("hidden");
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const formatDate = (dateStr: string) => {
    return new Date(dateStr).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" });
  };

  async function loadDropdownData() {
    try {
      const [playersRes, matchesRes] = await Promise.all([
        fetch("http://localhost:3000/api/players"),
        fetch("http://localhost:3000/api/matches")
      ]);

      if (!playersRes.ok || !matchesRes.ok) throw new Error("Failed to load backend data");

      const players = await playersRes.json();
      const matches = await matchesRes.json();

      playerSelect.innerHTML = '<option value="" disabled selected>Select a player...</option>';
      players.forEach((p: any) => {
        const option = document.createElement("option");
        option.value = p.player_id;
        option.textContent = `${p.player_name} (${p.team})`;
        playerSelect.appendChild(option);
      });

      matchSelect.innerHTML = '<option value="" disabled selected>Select a match...</option>';
      matches.forEach((m: any) => {
        const option = document.createElement("option");
        option.value = m.match_id;
        option.textContent = `${m.match_id} — ${m.stadium} (${formatDate(m.match_date)})`;
        matchSelect.appendChild(option);
      });

    } catch (error) {
      console.error(error);
      showNotification("Could not connect to the local server.", true);
    }
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.innerHTML = `Saving...`;

    const formData = new FormData(form);
    const payload: Record<string, any> = {};
    
    for (const [key, value] of formData.entries()) {
      if (value !== "") {
        if (key !== "player_id" && key !== "match_id" && key !== "match_result" && key !== "opponent_team" && !isNaN(Number(value))) {
          payload[key] = Number(value);
        } else {
          payload[key] = value;
        }
      }
    }

    try {
      const response = await fetch("http://localhost:3000/api/performances", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.details || errorData.error || "Failed to create performance");
      }

      showNotification("Performance successfully recorded!", false);
      setTimeout(() => { window.location.href = "/"; }, 1000);

    } catch (error: any) {
      console.error(error);
      showNotification(error.message, true);
      submitBtn.disabled = false;
      submitBtn.innerHTML = "Save Performance";
    }
  });

  loadDropdownData();
</script>