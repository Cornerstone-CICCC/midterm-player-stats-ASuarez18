---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Add Performance">
  <!-- > HEADER -->
  <div class="mb-6">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to Performances
    </a>
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Add Performance</h2>
    </div>
  </div>

  <!-- > NOTIFICATION TOAST -->
  <div id="notification-banner" class="hidden p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all">
    <svg id="notification-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"></svg>
    <span id="notification-text"></span>
  </div>

  <form id="create-performance-form" class="space-y-6 pb-28">
    
    <!-- > 1. PLAYER & MATCH INFO -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- Player selection -->
        <div class="space-y-4">
          <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Player Selection
          </h3>
          <div class="flex flex-col gap-1.5">
            <label for="player_id" class="text-xs font-semibold text-slate-600">Select Player <span class="text-rose-500">*</span></label>
            <select id="player_id" name="player_id" required class="w-full bg-slate-50 border border-slate-200 text-slate-800 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden transition-all">
              <option value="" disabled selected>Loading players...</option>
            </select>
          </div>
          <!-- Player preview card -->
          <div id="player-preview-card" class="hidden items-center gap-4 bg-slate-50 border border-slate-200 p-4 rounded-xl transition-all">
            <div id="player-preview-avatar" class="w-12 h-12 rounded-full bg-blue-100 text-blue-600 font-bold text-sm flex items-center justify-center border border-blue-200 uppercase shrink-0"></div>
            <div>
              <h4 id="player-preview-name" class="font-bold text-slate-900 leading-tight"></h4>
              <p id="player-preview-meta" class="text-xs text-slate-500 font-medium mt-1"></p>
            </div>
          </div>
        </div>

        <!-- Match selection-->
        <div class="space-y-4">
          <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line></svg>
            Match Selection
          </h3>
          <div class="flex flex-col gap-1.5">
            <label for="match_id" class="text-xs font-semibold text-slate-600">Select Match <span class="text-rose-500">*</span></label>
            <select id="match_id" name="match_id" required class="w-full bg-slate-50 border border-slate-200 text-slate-800 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden transition-all">
              <option value="" disabled selected>Loading matches...</option>
            </select>
          </div>
          <!-- Match preview card -->
          <div id="match-preview-card" class="hidden items-center gap-4 bg-slate-50 border border-slate-200 p-4 rounded-xl transition-all">
            <div class="w-12 h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center border border-amber-200 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </div>
            <div>
              <h4 id="match-preview-stadium" class="font-bold text-slate-900 leading-tight"></h4>
              <p id="match-preview-meta" class="text-xs text-slate-500 font-medium mt-1"></p>
            </div>
          </div>
        </div>

      </div>

      <!-- Extra data from match -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6 pt-6 border-t border-slate-100">
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Opponent Team</label>
          <input type="text" name="opponent_team" placeholder="e.g. Senegal" required class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Match Result</label>
          <select name="match_result" required class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700 cursor-pointer">
            <option value="" disabled selected>Select...</option>
            <option value="W">Win (W)</option>
            <option value="D">Draw (D)</option>
            <option value="L">Loss (L)</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Team Goals</label>
          <input type="number" name="goals_team" value="0" required class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Opponent Goals</label>
          <input type="number" name="goals_opponent" value="0" required class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>
      </div>
    </div>

    <!-- > 2. PERFORMANCE METRIC CARDS  -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <!-- - ATTACKING CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
        <div>
          <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
            Attacking Stats
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
            {[
              { id: "goals", label: "Goals" },
              { id: "assists", label: "Assists" },
              { id: "shots", label: "Shots" },
              { id: "shots_on_target", label: "On Target" },
              { id: "expected_goals_xg", label: "xG", step: "0.1" },
              { id: "expected_assists_xa", label: "xA", step: "0.1" },
              { id: "key_passes", label: "Key Passes" },
              { id: "total_passes", label: "Total Passes" },
              { id: "successful_passes", label: "Succ. Passes" },
              { id: "crosses", label: "Crosses" },
              { id: "successful_crosses", label: "Succ. Crosses" },
              { id: "dribbles_attempted", label: "Dribbles Att." },
              { id: "successful_dribbles", label: "Succ. Dribbles" },
              { id: "offsides", label: "Offsides" }
            ].map(field => (
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">{field.label}</label>
                <input type="number" step={field.step || "1"} name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- - DEFENSIVE CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
        <div>
          <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            Defensive Stats
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
            {[
              { id: "tackles", label: "Tackles" },
              { id: "interceptions", label: "Interceptions" },
              { id: "clearances", label: "Clearances" },
              { id: "blocks", label: "Blocks" },
              { id: "recoveries", label: "Recoveries" },
              { id: "defensive_actions", label: "Def. Actions" },
              { id: "aerial_duels_won", label: "Duels Won" },
              { id: "aerial_duels_lost", label: "Duels Lost" },
              { id: "fouls_committed", label: "Fouls Com." },
              { id: "fouls_suffered", label: "Fouls Drawn" },
              { id: "yellow_cards", label: "Yellow Cards" },
              { id: "red_cards", label: "Red Cards" }
            ].map(field => (
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">{field.label}</label>
                <input type="number" name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- - PHYSICAL CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
        <div>
          <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path><line x1="12" y1="2" x2="12" y2="12"></line></svg>
            Physical Metrics
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
            {[
              { id: "minutes_played", label: "Minutes" },
              { id: "distance_covered_km", label: "Distance (km)", step: "0.1" },
              { id: "sprint_distance_km", label: "Sprint (km)", step: "0.1" },
              { id: "top_speed_kmh", label: "Top Speed", step: "0.1" },
              { id: "accelerations", label: "Accelerations" },
              { id: "decelerations", label: "Decelerations" },
              { id: "stamina_score", label: "Stamina", step: "0.1" }
            ].map(field => (
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">{field.label}</label>
                <input type="number" step={field.step || "1"} name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- - GOALKEEPING CARD (if player is goalkeeper) -->
      <div id="goalkeeping-card" class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between hidden">
        <div>
          <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M18.6 18.6L12 12l-6.6 6.6M12 12V2"></path></svg>
            Goalkeeping Stats
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
            {[
              { id: "saves", label: "Saves" },
              { id: "save_percentage", label: "Save %", step: "0.1" },
              { id: "punches", label: "Punches" },
              { id: "goals_conceded", label: "Goals Conceded" },
              { id: "penalty_saves", label: "Penalty Saves" },
              { id: "clean_sheet", label: "Clean Sheet" }
            ].map(field => (
              <div class="flex flex-col gap-1">
                <label class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">{field.label}</label>
                <input type="number" step={field.step || "1"} name={field.id} value="0" class="w-full border border-slate-200 py-1.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- - PERFORMANCE CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm lg:col-span-2">
        <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          Performance Scores 
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-4">
          
          <!-- Match Rating -->
          <div class="flex flex-col gap-1">
            <label class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">Match Rating (1-10)</label>
            <input 
              type="number" 
              step="0.1" 
              name="player_rating" 
              value="0" 
              data-scale="10" 
              class="w-full py-2 px-3 rounded-lg text-sm font-bold focus:outline-hidden transition-all duration-200" 
            />
          </div>

          <!-- Other ratings -->
          {[
            { id: "pass_accuracy", label: "Pass Acc. %" },
            { id: "performance_score", label: "Perf. Score" },
            { id: "offensive_contribution", label: "Offensive" },
            { id: "defensive_contribution", label: "Defensive" },
            { id: "possession_impact", label: "Poss. Impact" },
            { id: "pressure_resistance", label: "Press. Resist" },
            { id: "creativity_score", label: "Creativity" },
            { id: "consistency_score", label: "Consistency" },
            { id: "clutch_performance_score", label: "Clutch Perf." }
          ].map(field => (
            <div class="flex flex-col gap-1">
              <label class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">{field.label}</label>
              <input 
                type="number" 
                step="0.1" 
                name={field.id} 
                value="0" 
                data-scale="100" 
                class="w-full py-2 px-3 rounded-lg text-sm font-bold focus:outline-hidden transition-all duration-200" 
              />
            </div>
          ))}

        </div>
      </div>

    </div>

    <!-- > 3. ACTION BUTTONS  -->
    <div class="fixed bottom-0 left-0 md:left-64 right-0 bg-white border-t border-slate-200 p-4 px-6 flex justify-end gap-3 z-10 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
      <button type="button" onclick="window.history.back()" class="px-6 py-2.5 text-sm font-semibold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer">
        Cancel
      </button>
      <button type="submit" id="submit-btn" class="px-8 py-2.5 text-sm font-semibold text-white bg-[#2563eb] hover:bg-blue-700 rounded-xl shadow-md shadow-blue-500/20 transition-colors flex items-center gap-2 cursor-pointer">
        Save Performance
      </button>
    </div>
  </form>
</Layout>

<script>
  import { formatDate, getInitials, getFlagEmoji } from "../../../utils/helpers.ts";

  // > --- DOM ELEMENTS ---
  const form = document.getElementById("create-performance-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const playerSelect = document.getElementById("player_id") as HTMLSelectElement;
  const matchSelect = document.getElementById("match_id") as HTMLSelectElement;
  
  // > --- PREVIEW CARDS ---
  const playerPreviewCard = document.getElementById("player-preview-card");
  const playerPreviewAvatar = document.getElementById("player-preview-avatar");
  const playerPreviewName = document.getElementById("player-preview-name");
  const playerPreviewMeta = document.getElementById("player-preview-meta");

  const matchPreviewCard = document.getElementById("match-preview-card");
  const matchPreviewStadium = document.getElementById("match-preview-stadium");
  const matchPreviewMeta = document.getElementById("match-preview-meta");

  const goalkeepingCard = document.getElementById("goalkeeping-card");

  // > --- NOTIFICATION BANNER ---
  const banner = document.getElementById("notification-banner");
  const bannerText = document.getElementById("notification-text");
  const bannerIcon = document.getElementById("notification-icon");

  // > --- RAW DATA ARRAYS ---
  let rawPlayers: any[] = [];
  let rawMatches: any[] = [];

  // --- Utils ---

  /**
   * @function showNotification
   * @description Displays a notification banner with a message and an icon indicating success or error.
   * @param message - The message to display in the notification banner.
   * @param isError - A boolean indicating whether the notification is an error (true) or success (false).
   * @returns {void}
   */
  const showNotification = (message: string, isError: boolean) => {
    if (!banner || !bannerText || !bannerIcon) return;
    
    banner.className = `p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all ${isError ? 'bg-rose-50 text-rose-700 border border-rose-200' : 'bg-green-50 text-green-700 border border-green-200'}`;
    bannerText.textContent = message;
    bannerIcon.innerHTML = isError 
      ? '<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>' 
      : '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>';
    banner.classList.remove("hidden");

    const mainContainer = document.querySelector("main");
      if (mainContainer) {
        mainContainer.scrollTo({ top: 0, behavior: 'smooth' });
    }
  };

  // --- > REALTIME COLORING OF RATING INPUTS ---
  // Get all rating inputs with the data-scale attribute
  const ratingInputs = document.querySelectorAll<HTMLInputElement>('input[data-scale]');

  /**
   * @function updateInputColor
   * @description Updates the background and text color of a rating input based on its value and scale.
   * @param input - The HTMLInputElement whose color needs to be updated.
   * @returns {void}
   */
  function updateInputColor(input: HTMLInputElement) {
    const val = parseFloat(input.value) || 0;
    const scale = input.getAttribute('data-scale');
    
    // Remove all previous color classes
    input.classList.remove(
      'bg-green-50', 'text-green-700', 'border-green-200', 'focus:border-green-500', 'focus:ring-green-500/10',
      'bg-amber-50', 'text-amber-700', 'border-amber-200', 'focus:border-amber-500', 'focus:ring-amber-500/10',
      'bg-rose-50', 'text-rose-700', 'border-rose-200', 'focus:border-rose-500', 'focus:ring-rose-500/10',
      'border-slate-200', 'text-slate-700'
    );
    
    let colorClass = '';
    if (scale === '10') {
      if (val >= 7.5) {
        colorClass = 'bg-green-50 text-green-700 border-green-200 focus:border-green-500 focus:ring-green-500/10';
      } else if (val >= 6.5) {
        colorClass = 'bg-amber-50 text-amber-700 border-amber-200 focus:border-amber-500 focus:ring-amber-500/10';
      } else {
        colorClass = 'bg-rose-50 text-rose-700 border-rose-200 focus:border-rose-500 focus:ring-rose-500/10';
      }
    } else { // 100 Scale
      if (val >= 75) {
        colorClass = 'bg-green-50 text-green-700 border-green-200 focus:border-green-500 focus:ring-green-500/10';
      } else if (val >= 65) {
        colorClass = 'bg-amber-50 text-amber-700 border-amber-200 focus:border-amber-500 focus:ring-amber-500/10';
      } else {
        colorClass = 'bg-rose-50 text-rose-700 border-rose-200 focus:border-rose-500 focus:ring-rose-500/10';
      }
    }
    
    input.className = `w-full border py-1.5 px-3 rounded-lg text-sm font-bold focus:ring-2 focus:outline-hidden transition-all duration-200 ${colorClass}`;
  }

  ratingInputs.forEach(input => {
    updateInputColor(input); // On page load coloring
    input.addEventListener('input', () => updateInputColor(input)); // Real time coloring
  });

  // --- > SELECT DROPDOWN DATA LOADING ---
  /**
   * @function loadDropdownData
   * @description Fetches player and match data from the backend API and populates the respective dropdowns
   * @returns {Promise<void>}   
   */
  async function loadDropdownData() {
    try {
      const [playersRes, matchesRes] = await Promise.all([
        fetch("http://localhost:3000/api/players"),
        fetch("http://localhost:3000/api/matches")
      ]);

      if (!playersRes.ok || !matchesRes.ok) throw new Error("Could not retrieve master catalog details from server.");

      rawPlayers = await playersRes.json();
      rawMatches = await matchesRes.json();

      // Fill player selector
      playerSelect.innerHTML = '<option value="" disabled selected>Select a player...</option>';
      rawPlayers.forEach((p: any) => {
        const opt = document.createElement("option");
        opt.value = p.player_id;
        opt.textContent = `${p.player_name} (${p.team})`;
        playerSelect.appendChild(opt);
      });

      // Fill match selector
      matchSelect.innerHTML = '<option value="" disabled selected>Select a match...</option>';
      rawMatches.forEach((m: any) => {
        const opt = document.createElement("option");
        opt.value = m.match_id;
        opt.textContent = `${m.match_id} — ${m.stadium} (${formatDate(m.match_date)})`;
        matchSelect.appendChild(opt);
      });

    } catch (error) {
      console.error(error);
      showNotification("Could not connect to the backend server on port 3000.", true);
    }
  }

  // --- > STRICT INPUT VALIDATION FOR NUMBER FIELDS ---
  const allNumberInputs = document.querySelectorAll<HTMLInputElement>('input[type="number"]');

  allNumberInputs.forEach(input => {
    // 1. Block negative numbers from being typed using the keyboard and scientific notation (e.g., "e" or "E")
    input.addEventListener('keydown', (e) => {
      if (e.key === '-' || e.key === 'e' || e.key === 'E') {
        e.preventDefault();
      }
    });

    // 2. Ensure that if a negative number is pasted or entered, it resets to 0 and updates the color if it's a rating input
    input.addEventListener('input', () => {
      const val = parseFloat(input.value);
      if (val < 0) {
        input.value = "0";
        // If input is 
        if (input.hasAttribute('data-scale')) {
          updateInputColor(input);
        }
      }
    });
  });

  // --- > SELECT CHANGE EVENTS ---
  /**
   * @function handleSelectChange
   * @description Handles the change event for player and match selection dropdowns, updating the preview cards accordingly.
   * @param e - The change event triggered by the select element.
   * @returns {void}
   */
  playerSelect.addEventListener("change", (e) => {
    const target = e.target as HTMLSelectElement;
    const player = rawPlayers.find(p => p.player_id === target.value);

    if (player && playerPreviewCard && playerPreviewAvatar && playerPreviewName && playerPreviewMeta) {
      playerPreviewAvatar.textContent = getInitials(player.player_name);
      playerPreviewName.textContent = player.player_name;
      playerPreviewMeta.innerHTML = `${getFlagEmoji(player.team)} ${player.team} · #${player.jersey_number} · <span class="font-bold text-blue-600">${player.position}</span>`;
      playerPreviewCard.classList.replace("hidden", "flex");

      // Enable or disable the goalkeeping card based on the player's position
      if (player.position === "Goalkeeper") {
        goalkeepingCard?.classList.remove("hidden");
      } else {
        goalkeepingCard?.classList.add("hidden");
      }
    }
  });

  /**
   * @function handleMatchSelectChange
   * @description Handles the change event for the match selection dropdown, updating the match preview card with relevant match details
   * @param e - The change event triggered by the match select element.
   * @returns {void}
   */
  matchSelect.addEventListener("change", (e) => {
    const target = e.target as HTMLSelectElement;
    const match = rawMatches.find(m => m.match_id === target.value);

    if (match && matchPreviewCard && matchPreviewStadium && matchPreviewMeta) {
      matchPreviewStadium.textContent = match.stadium;
      matchPreviewMeta.textContent = `${match.city} · ${formatDate(match.match_date)} · Stage: ${match.tournament_stage}`;
      matchPreviewCard.classList.replace("hidden", "flex");
    }
  });

  // --- > FORM SUBMISSION ---
  /**
   * @function handleFormSubmit
   * @description Handles the form submission event, sending the performance data to the backend API and providing user feedback
   * @param e - The submit event triggered by the form.
   * @returns {Promise<void>}
   */
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.innerHTML = `Saving...`;

    const formData = new FormData(form);
    const payload: Record<string, any> = {};
    
    for (const [key, value] of formData.entries()) {
      if (value !== "") {
        // Verify if field is number
        if (
          key !== "player_id" && 
          key !== "match_id" && 
          key !== "match_result" && 
          key !== "opponent_team" && 
          !isNaN(Number(value))
        ) {
          const parsedValue = Number(value);

          // 3. Payload validation: Ensure that no negative values are sent to the backend
          if (parsedValue < 0) {
            const readableName = key.replace(/_/g, ' ').toUpperCase();
            showNotification(`Validation Error: ${readableName} cannot be a negative value.`, true);
            
            // Restore the submit button state to allow user to correct the input
            submitBtn.disabled = false;
            submitBtn.innerHTML = "Save Performance";
            return; // Stops the submission process if a negative value is detected
          }

          payload[key] = parsedValue;
        } else {
          payload[key] = value;
        }
      }
    }

    try {
      const response = await fetch("http://localhost:3000/api/performances", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.details || errorData.error || "Failed to create performance statistics.");
      }
      console.log("response", response);

      showNotification("Performance recorded successfully!", false);
      setTimeout(() => { window.location.href = "/"; }, 2000);

    } catch (error: any) {
      console.error(error);
      showNotification(error.message, true);
      submitBtn.disabled = false;
      submitBtn.innerHTML = "Save Performance";
    }
  });

  // --- > INITIAL DATA ON PAGE LOAD ---
  loadDropdownData();
</script>