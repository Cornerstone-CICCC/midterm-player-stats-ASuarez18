---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Add Match Fixture">
  <!-- > HEADER -->
  <div class="mb-6">
    <a href="/matches" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to Matches
    </a>
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Add Match Fixture</h2>
    </div>
  </div>

  <!-- > NOTIFICATION TOAST -->
  <div id="notification-banner" class="hidden p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all">
    <svg id="notification-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"></svg>
    <span id="notification-text"></span>
  </div>

  <form id="create-match-form" class="space-y-6 pb-28">
    
    <!-- > 1. Match Details -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        Match Details
      </h3>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <!-- - Match ID -->
        <div class="flex flex-col gap-1.5 md:col-span-1">
          <label for="match_id" class="text-xs font-semibold text-slate-600">Match Token ID <span class="text-rose-500">*</span></label>
          <input type="text" id="match_id" name="match_id" required placeholder="e.g. M00370" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700 font-mono" />
        </div>

        <!-- - Match Date -->
        <div class="flex flex-col gap-1.5 md:col-span-3">
          <label for="match_date" class="text-xs font-semibold text-slate-600">Date & Time <span class="text-rose-500">*</span></label>
          <input type="datetime-local" id="match_date" name="match_date" required class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>
      </div>
    </div>

    <!-- > 2. LOCATION & TOURNAMENT STAGE -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        Logistics & Tournament Stage
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- - Match Stadium -->
        <div class="flex flex-col gap-1.5">
          <label for="stadium" class="text-xs font-semibold text-slate-600">Stadium <span class="text-rose-500">*</span></label>
          <input type="text" id="stadium" name="stadium" required placeholder="e.g. Lumen Field" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Match City -->
        <div class="flex flex-col gap-1.5">
          <label for="city" class="text-xs font-semibold text-slate-600">Host City <span class="text-rose-500">*</span></label>
          <input type="text" id="city" name="city" required placeholder="e.g. Seattle" class="w-full border border-slate-200 py-2 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700" />
        </div>

        <!-- - Match Stage -->
        <div class="flex flex-col gap-1.5">
          <label for="tournament_stage" class="text-xs font-semibold text-slate-600">Tournament Stage <span class="text-rose-500">*</span></label>
          <select id="tournament_stage" name="tournament_stage" required class="w-full border border-slate-200 py-2.5 px-3 rounded-lg text-sm font-semibold focus:border-blue-500 focus:outline-hidden text-slate-700 cursor-pointer">
            <option value="" disabled selected>Select stage...</option>
            <option value="Group Stage">Group Stage</option>
            <option value="Round of 32">Round of 32</option>
            <option value="Round of 16">Round of 16</option>
            <option value="Quarter-finals">Quarter-finals</option>
            <option value="Semi-finals">Semi-finals</option>
            <option value="Third place play-off">Third place play-off</option>
            <option value="Final">Final</option>
          </select>
        </div>
      </div>
    </div>

    <!-- > 3. ACTION BUTTONS -->
    <div class="fixed bottom-0 left-0 md:left-64 right-0 bg-white border-t border-slate-200 p-4 px-6 flex justify-end gap-3 z-10 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
      <button type="button" onclick="window.history.back()" class="px-6 py-2.5 text-sm font-semibold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer">
        Cancel
      </button>
      <button type="submit" id="submit-btn" class="px-8 py-2.5 text-sm font-semibold text-white bg-[#2563eb] hover:bg-blue-700 rounded-xl shadow-md shadow-blue-500/20 transition-colors flex items-center gap-2 cursor-pointer">
        Save Match Fixture
      </button>
    </div>
  </form>
</Layout>

<script>
  // > --- DOM ELEMENTS ---
  const form = document.getElementById("create-match-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  
  // > --- NOTIFICATION BANNER ---
  const banner = document.getElementById("notification-banner");
  const bannerText = document.getElementById("notification-text");
  const bannerIcon = document.getElementById("notification-icon");

  /**
   * @function showNotification
   * @description Displays a notification banner with a message and an icon indicating success or error.
   * @param message - The message to display in the notification banner.
   * @param isError - A boolean indicating whether the notification is an error (true) or success (false).
   * @returns {void}
   */
  const showNotification = (message: string, isError: boolean) => {
    if (!banner || !bannerText || !bannerIcon) return;
    
    banner.className = `p-4 mb-6 rounded-xl flex items-center gap-3 shadow-xs text-sm font-semibold transition-all ${isError ? 'bg-rose-50 text-rose-700 border border-rose-200' : 'bg-green-50 text-green-700 border border-green-200'}`;
    bannerText.textContent = message;
    bannerIcon.innerHTML = isError 
      ? '<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>' 
      : '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>';
    banner.classList.remove("hidden");

    const mainContainer = document.querySelector("main");
    if (mainContainer) {
      mainContainer.scrollTo({ top: 0, behavior: 'smooth' });
    }
  };

  // --- > FORM SUBMISSION ---
  /**
   * @function handleFormSubmit
   * @description Handles the form submission event, sending the performance data to the backend API and providing user feedback
   * @param e - The submit event triggered by the form.
   * @returns {Promise<void>}
   */
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.innerHTML = `Saving Fixture...`;

    const formData = new FormData(form);
    const payload: Record<string, any> = {};
    
    for (const [key, value] of formData.entries()) {
      if (value !== "") {
        if (key === "match_date") {
          // Transformar la entrada del datetime-local a formato estricto ISO string para PostgreSQL TIMESTAMP
          payload[key] = new Date(value as string).toISOString();
        } else {
          payload[key] = value;
        }
      }
    }

    try {
      const response = await fetch("http://localhost:3000/api/matches", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.details || errorData.error || "Failed to catalog new match fixture details.");
      }

      showNotification("Match fixture created and indexed successfully!", false);
      setTimeout(() => { window.location.href = "/matches"; }, 2000);

    } catch (error: any) {
      console.error(error);
      showNotification(error.message, true);
      submitBtn.disabled = false;
      submitBtn.innerHTML = "Save Match Fixture";
    }
  });
</script>