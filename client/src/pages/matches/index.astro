---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Matches">
  <!-- CABECERA -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h2 class="text-3xl font-bold tracking-tight text-slate-900">Matches</h2>
      <p class="text-slate-500 mt-1">View and manage the tournament match schedule.</p>
    </div>

    <a
      href="/matches/create"
      class="inline-flex items-center justify-center gap-2 bg-[#2563eb] hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-xl text-sm shadow-md shadow-blue-500/10 hover:shadow-lg transition-all"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      Add Match
    </a>
  </div>

  <!-- BANNER DE ERROR -->
  <div id="error-banner" class="hidden bg-rose-50 border border-rose-100 text-rose-700 p-6 rounded-2xl items-center gap-4 shadow-xs mb-6">
    <div class="bg-rose-100 p-3 rounded-xl text-rose-600 shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
    </div>
    <div>
      <h4 class="font-bold">Backend Connection Error</h4>
      <p id="error-text" class="text-sm text-rose-600/90 mt-1">Could not load matches.</p>
    </div>
  </div>

  <!-- TABLA DE PARTIDOS -->
  <div class="bg-white border border-slate-100 rounded-3xl shadow-xs overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-left text-sm text-slate-600">
        <thead>
          <tr class="bg-slate-50/75 border-b border-slate-100 text-xs font-bold uppercase tracking-wider text-slate-400">
            <th class="px-6 py-4">Match ID</th>
            <th class="px-6 py-4">Date</th>
            <th class="px-6 py-4 hidden sm:table-cell">Stadium</th>
            <th class="px-6 py-4 hidden md:table-cell">City</th>
            <th class="px-6 py-4 hidden lg:table-cell">Stage</th>
            <th class="px-6 py-4 text-center">Actions</th>
          </tr>
        </thead>
        <tbody id="matches-tbody" class="divide-y divide-slate-100/60">
          <!-- Renderizado dinámico -->
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  const tbody = document.getElementById("matches-tbody");
  const errorBanner = document.getElementById("error-banner");
  const errorText = document.getElementById("error-text");

  const formatDate = (dateStr: string): string => {
    return new Date(dateStr).toLocaleDateString("en-GB", { 
      day: "2-digit", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" 
    });
  };

  async function loadMatches() {
    if (!tbody) return;
    
    // Spinner de carga
    tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-slate-400"><div class="flex items-center justify-center gap-2"><svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Loading matches...</div></td></tr>`;
    errorBanner?.classList.add("hidden");

    try {
      const response = await fetch("http://localhost:3000/api/matches");
      if (!response.ok) throw new Error("Could not fetch matches.");
      const matches = await response.json();
      
      tbody.innerHTML = "";
      
      if (matches.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-8 text-center text-slate-400">No matches scheduled.</td></tr>`;
        return;
      }

      matches.forEach((m: any) => {
        const tr = document.createElement("tr");
        tr.className = "hover:bg-slate-50/40 transition-colors";
        
        tr.innerHTML = `
          <td class="px-6 py-4 font-bold text-slate-900 font-mono">${m.match_id}</td>
          <td class="px-6 py-4 text-slate-600">${formatDate(m.match_date)}</td>
          <td class="px-6 py-4 text-slate-700 font-medium hidden sm:table-cell">${m.stadium}</td>
          <td class="px-6 py-4 text-slate-600 hidden md:table-cell">${m.city}</td>
          <td class="px-6 py-4 hidden lg:table-cell">
            <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase rounded-lg">${m.tournament_stage}</span>
          </td>
          <td class="px-6 py-4 text-center">
            <a href="/matches/edit/${m.match_id}" class="text-blue-600 hover:text-blue-800 p-2 hover:bg-blue-50 rounded-lg transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
            </a>
          </td>
        `;
        tbody.appendChild(tr);
      });
    } catch (err) {
      console.error(err);
      tbody.innerHTML = "";
      if (errorBanner && errorText) {
        errorBanner.classList.remove("hidden");
        errorBanner.classList.add("flex");
        errorText.textContent = "Could not connect to the backend server.";
      }
    }
  }

  loadMatches();
</script>